// Prisma schema for Budget Tracker
// Choice: Prisma over TypeORM — better DX, type-safe client, cleaner migrations

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  password     String
  name         String
  role         Role      @default(USER)
  refreshToken String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  budgets      Budget[]
  expenses     Expense[]

  @@map("users")
}

model Category {
  id        String    @id @default(uuid())
  name      String    @unique
  icon      String?
  color     String?
  createdAt DateTime  @default(now())
  budgets   Budget[]
  expenses  Expense[]

  @@map("categories")
}

model Budget {
  id           String   @id @default(uuid())
  name         String
  monthlyLimit Decimal  @db.Decimal(12, 2)
  month        Int
  year         Int
  userId       String
  categoryId   String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category  @relation(fields: [categoryId], references: [id])
  expenses Expense[]

  @@unique([userId, categoryId, month, year])
  @@map("budgets")
}

model Expense {
  id          String   @id @default(uuid())
  amount      Decimal  @db.Decimal(12, 2)
  description String?
  date        DateTime
  userId      String
  budgetId    String?
  categoryId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budget   Budget?  @relation(fields: [budgetId], references: [id])
  category Category @relation(fields: [categoryId], references: [id])

  @@map("expenses")
}
